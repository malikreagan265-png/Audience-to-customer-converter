<script>
const FAQS = [
  { q:"Why does my audience not buy from me?", a:"The most common reasons are: no email list to bridge social followers to a sales environment, an unclear offer where people don't know exactly what they're buying, insufficient promotion frequency (most sales happen after the 5th touchpoint), a trust gap where your content doesn't prove you can deliver the transformation, and pricing signals that feel misaligned with perceived value. The Funnel Audit identifies which of these is your primary leak." },
  { q:"How do I convert social media followers into customers?", a:"The most reliable path has three steps: move them from social to email (conversion rates are 10–20x higher), deliver consistent value that builds trust, then make offers that are specific, clearly positioned, and repeated regularly. The three tools in the Converter address each of these steps directly." },
  { q:"How many emails does it take to convert a follower into a buyer?", a:"Research consistently shows most sales happen between the 5th and 12th touchpoint. A cold follower who receives one sales email will convert at a fraction of the rate of someone who has received 5 trust-building emails before the offer. The sequence builder is structured to deliver value in emails 1–4 before making the direct offer in email 5." },
  { q:"What format is the tool?", a:"A single HTML file. Open in any browser — no install, no login, no subscription. The Funnel Audit and Email Sequence Builder use the Claude AI API, so those features require an internet connection. The Offer Positioning Frameworks work fully offline." },
  { q:"Does this work for any type of offer?", a:"Yes — digital products, courses, coaching, memberships, services, or physical products. The Funnel Audit and Offer Frameworks ask for your specific inputs and adapt accordingly. The Email Sequence Builder generates copy specific to your product, price, and transformation." },
  { q:"What if I'm not happy with it?", a:"7-day money-back guarantee. Email within 7 days of purchase for a full refund. No questions, no friction." }
];

const faqList = document.getElementById('faqList');
FAQS.forEach((f, i) => {
  const div = document.createElement('div');
  div.className = 'faq-item';
  div.innerHTML = `
    <button class="faq-q" onclick="toggleFaq(${i})">${f.q}<span class="faq-toggle" id="ftog${i}">+</span></button>
    <div class="faq-a" id="fans${i}">${f.a}</div>`;
  faqList.appendChild(div);
});

function toggleFaq(i) {
  const ans = document.getElementById('fans'+i);
  const tog = document.getElementById('ftog'+i);
  const open = ans.style.display === 'block';
  document.querySelectorAll('.faq-a').forEach(a => a.style.display = 'none');
  document.querySelectorAll('.faq-toggle').forEach(t => t.textContent = '+');
  if (!open) { ans.style.display = 'block'; tog.textContent = '−'; }
}

const obs = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) { e.target.style.opacity = '1'; e.target.style.transform = 'translateY(0)'; }
  });
}, { threshold: 0.07 });
document.querySelectorAll('.section').forEach(s => {
  s.style.opacity = '0';
  s.style.transform = 'translateY(18px)';
  s.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
  obs.observe(s);
});
</script>
</body>
